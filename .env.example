NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-local-supabase-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — required for /api/profile (Supabase Dashboard → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-local-supabase-service-role-key

# Local Supabase stack settings
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:54321
POSTGRES_PASSWORD=your-local-postgres-password
AUTH_JWT_SECRET=your-local-supabase-jwt-secret
GITHUB_ENABLED=true
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Optional — raises GitHub REST API rate limit (recommended for Cloudflare/production)
GITHUB_TOKEN=

# GitHub webhook — HMAC secret from repo/org webhook settings
GITHUB_WEBHOOK_SECRET=

# Redis — BullMQ queue + idempotency store (Upstash rediss://... or local redis://localhost:6379)
REDIS_URL=

# Embedded BullMQ worker: auto-on in development; set true for Docker/standalone `next start`
# Set false on Cloudflare/Vercel (processing uses post-response `after()` instead)
ENABLE_PR_EVENTS_WORKER=

# Version badge in navbar — auto-set from package.json at build time, no manual update needed
# NEXT_PUBLIC_APP_VERSION=0.9.0

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
# EU ingest: https://eu.i.posthog.com | US ingest: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=
# Set to true only when testing analytics locally with npm run dev
NEXT_PUBLIC_POSTHOG_ENABLED=
